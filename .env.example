# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Security - Comma-separated Telegram user IDs allowed to use the bot (leave empty to allow all)
ALLOWED_TELEGRAM_IDS=

# Allowed chat IDs - bot only responds in these chats (comma-separated)
ALLOWED_CHAT_IDS=-100123456789,123456789

# Working directory for Claude Code (where files are created/modified)
WORKSPACE_DIR=/app/workspace

# Company / Issuer (do NOT include country in address — build_contract.py appends ", Malaysia")
COMPANY_NAME=Your Company PLT
COMPANY_REG=000000000000
COMPANY_SST_NO=B00-0000-00000000
COMPANY_ADDRESS=Your Office Address, City, State
COMPANY_CONTACT_NAME=Your Name
COMPANY_CONTACT_TITLE=Director
COMPANY_EMAIL=you@example.com

# Bank
BANK_NAME=Your Bank
BANK_ACCT_NAME=Your Company PLT
BANK_ACCT_NO=000000000000

# Email
FROM_NAME=Your Name (Company)
FROM_EMAIL=you@example.com
CC_EMAILS=cc1@example.com,cc2@example.com

# Telegram Routing
TELEGRAM_GROUP_CHAT_ID=-100123456789
TELEGRAM_DM_CHAT_ID=123456789

# Browser (optional — Playwright auto-detects if not set)
PLAYWRIGHT_CHROME_PATH=
